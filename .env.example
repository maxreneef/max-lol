# ── Riot Games API ────────────────────────────────────────────────────────────
# Obtenha em https://developer.riotgames.com
# Sem esta variável, a busca usa dados de demonstração (mock).
RIOT_API_KEY=

# ── Anthropic (IA da página de campeão) ───────────────────────────────────────
# Obtenha em https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Google AdSense ────────────────────────────────────────────────────────────
# 1. Acesse https://adsense.google.com e crie sua conta
# 2. Adicione o site max-lol.vercel.app e aguarde aprovação (dias a semanas)
# 3. Copie o Publisher ID (formato: ca-pub-XXXXXXXXXXXXXXXXX)
# 4. Cole aqui e no public/ads.txt
# 5. Crie 3 unidades de anúncio no painel e cole os Slot IDs abaixo
NEXT_PUBLIC_ADSENSE_PUB_ID=
NEXT_PUBLIC_ADSENSE_SLOT_BANNER=   # 728x90 horizontal — entre abas e conteúdo
NEXT_PUBLIC_ADSENSE_SLOT_RECT=     # 300x250 retângulo — entre seções
NEXT_PUBLIC_ADSENSE_SLOT_LEFT=     # 160x600 sidebar esquerda (desktop ≥1380px)
NEXT_PUBLIC_ADSENSE_SLOT_RIGHT=    # 160x600 sidebar direita  (desktop ≥1380px)
NEXT_PUBLIC_ADSENSE_SLOT_STICKY=   # 320x50 sticky bottom (mobile)

# ── Ko-fi ─────────────────────────────────────────────────────────────────────
# 1. Crie conta em https://ko-fi.com
# 2. Cole seu username aqui (ex: se seu perfil for ko-fi.com/maxlol → "maxlol")
NEXT_PUBLIC_KOFI_USERNAME=

# ── Amazon Associates ─────────────────────────────────────────────────────────
# 1. Cadastre-se em https://associados.amazon.com.br
# 2. Cole sua Tracking ID (ex: maxlol-20)
# 3. Substitua as URLs placeholder na página /suporte pelos links reais gerados
NEXT_PUBLIC_AMAZON_TAG=
